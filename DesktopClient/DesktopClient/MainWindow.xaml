<Window x:Class="DesktopClient.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DesktopClient"
        xmlns:vm="clr-namespace:DesktopClient.ViewModels"
        mc:Ignorable="d"
        Title="Smart PDF Reader - Chat" Height="720" Width="980"
        MinHeight="520" MinWidth="760"
        Background="#0B0F14">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </Window.Resources>

    <!-- DataContext set in code-behind with ChatOptions from configuration -->

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" CornerRadius="12" Background="#121826" BorderBrush="#1F2937" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0" Margin="14,12" LastChildFill="False">
                    <TextBlock Text="Conversation" Foreground="#E5E7EB" FontSize="16" FontWeight="SemiBold" />
                    <TextBlock Margin="12,0,0,0"
                               Text="{Binding Messages.Count, Mode=OneWay, StringFormat={}{0} messages}"
                               Foreground="#9CA3AF" FontSize="12" VerticalAlignment="Bottom" />
                </DockPanel>

                <ScrollViewer Grid.Row="1" Margin="14,0,14,14" VerticalScrollBarVisibility="Auto" x:Name="ConversationScrollViewer">
                    <StackPanel>
                        <ItemsControl ItemsSource="{Binding Messages}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>

                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,8,0,0"
                                            CornerRadius="10"
                                            Background="#0F172A"
                                            BorderBrush="#1F2937"
                                            BorderThickness="1"
                                            Padding="12">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="190" />
                                                <ColumnDefinition Width="14" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>

                                            <!-- Left: timestamp + role -->
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="{Binding Timestamp, StringFormat={}{0:yyyy-MM-dd HH:mm:ss}}"
                                                           Foreground="#9CA3AF"
                                                           FontSize="12" />
                                                <TextBlock Text="{Binding Role}"
                                                           Foreground="#E5E7EB"
                                                           FontSize="13"
                                                           FontWeight="SemiBold"
                                                           Margin="0,4,0,0" />
                                            </StackPanel>

                                            <Border Grid.Column="1" Background="#1F2937" Width="1" />

                                            <!-- Right: message content -->
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding Content}"
                                                       Foreground="#E5E7EB"
                                                       FontSize="14"
                                                       TextWrapping="Wrap"
                                                       LineHeight="20" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Writing indicator under last message: no time, just "Writing..." + animation -->
                        <Border Margin="0,8,0,0"
                                Padding="12"
                                CornerRadius="10"
                                Background="#0F172A"
                                BorderBrush="#1F2937"
                                BorderThickness="1"
                                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="Writing" Foreground="#9CA3AF" FontSize="14" FontWeight="SemiBold" />
                                <TextBlock Text=" " />
                                <TextBlock Text="." Foreground="#9CA3AF" FontSize="18" FontWeight="Bold" Opacity="0.2" Margin="0,0,4,0">
                                    <TextBlock.Triggers>
                                        <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                                            <BeginStoryboard>
                                                <Storyboard RepeatBehavior="Forever">
                                                    <DoubleAnimationUsingKeyFrames Duration="0:0:1.2" Storyboard.TargetProperty="Opacity">
                                                        <DiscreteDoubleKeyFrame KeyTime="0:0:0" Value="0.2" />
                                                        <LinearDoubleKeyFrame KeyTime="0:0:0.3" Value="1" />
                                                        <LinearDoubleKeyFrame KeyTime="0:0:0.6" Value="0.2" />
                                                    </DoubleAnimationUsingKeyFrames>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                    </TextBlock.Triggers>
                                </TextBlock>
                                <TextBlock Text="." Foreground="#9CA3AF" FontSize="18" FontWeight="Bold" Opacity="0.2" Margin="0,0,4,0">
                                    <TextBlock.Triggers>
                                        <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                                            <BeginStoryboard>
                                                <Storyboard RepeatBehavior="Forever">
                                                    <DoubleAnimationUsingKeyFrames Duration="0:0:1.2" Storyboard.TargetProperty="Opacity">
                                                        <DiscreteDoubleKeyFrame KeyTime="0:0:0" Value="0.2" />
                                                        <LinearDoubleKeyFrame KeyTime="0:0:0.4" Value="1" />
                                                        <LinearDoubleKeyFrame KeyTime="0:0:0.7" Value="0.2" />
                                                    </DoubleAnimationUsingKeyFrames>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                    </TextBlock.Triggers>
                                </TextBlock>
                                <TextBlock Text="." Foreground="#9CA3AF" FontSize="18" FontWeight="Bold" Opacity="0.2">
                                    <TextBlock.Triggers>
                                        <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                                            <BeginStoryboard>
                                                <Storyboard RepeatBehavior="Forever">
                                                    <DoubleAnimationUsingKeyFrames Duration="0:0:1.2" Storyboard.TargetProperty="Opacity">
                                                        <DiscreteDoubleKeyFrame KeyTime="0:0:0" Value="0.2" />
                                                        <LinearDoubleKeyFrame KeyTime="0:0:0.8" Value="1" />
                                                        <LinearDoubleKeyFrame KeyTime="0:0:1.1" Value="0.2" />
                                                    </DoubleAnimationUsingKeyFrames>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                    </TextBlock.Triggers>
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- Input + actions -->
        <Border Grid.Row="1" Margin="0,14,0,0" CornerRadius="12" Background="#121826" BorderBrush="#1F2937" BorderThickness="1" Padding="14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="14" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="10" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBox Grid.Column="0" Grid.Row="0"
                         Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"
                         MinHeight="42"
                         Padding="12,10"
                         FontSize="14"
                         Foreground="#E5E7EB"
                         Background="#0B1220"
                         BorderBrush="#1F2937"
                         BorderThickness="1"
                         CaretBrush="#E5E7EB"
                         VerticalContentAlignment="Center">
                    <TextBox.InputBindings>
                        <KeyBinding Key="Enter" Command="{Binding SubmitCommand}" />
                    </TextBox.InputBindings>
                </TextBox>

                <StackPanel Grid.Column="0" Grid.Row="1" Margin="2,8,0,0">
                    <TextBlock Foreground="#9CA3AF" FontSize="12">
                        <Run Text="Rules: " />
                        <Run Text="{Binding MinContentLength, Mode=OneWay}" />
                        <Run Text="–" />
                        <Run Text="{Binding MaxContentLength, Mode=OneWay}" />
                        <Run Text=" characters" />
                        <Run Text=" • " />
                        <Run Text="{Binding InputText.Length, Mode=OneWay}" />
                        <Run Text=" typed" />
                    </TextBlock>

                    <TextBlock Foreground="#F87171" FontSize="12" Text="{Binding StatusText}" Margin="0,6,0,0" />
                </StackPanel>

                <Button Grid.Column="2" Grid.Row="0"
                        MinWidth="110" MinHeight="42"
                        Padding="14,0"
                        Content="Submit"
                        Command="{Binding SubmitCommand}"
                        IsEnabled="{Binding IsSubmitButtonEnabled}"
                        Background="#2563EB"
                        Foreground="White"
                        BorderBrush="#1D4ED8"
                        BorderThickness="1" />

                <Button Grid.Column="4" Grid.Row="0"
                        MinWidth="170" MinHeight="42"
                        Padding="14,0"
                        Content="Delete conversation"
                        Command="{Binding DeleteConversationCommand}"
                        IsEnabled="{Binding IsDeleteButtonEnabled}"
                        Background="#111827"
                        Foreground="#E5E7EB"
                        BorderBrush="#374151"
                        BorderThickness="1" />
            </Grid>
        </Border>

    </Grid>
</Window>
